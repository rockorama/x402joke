# Address that will receive USDC payments for jokes.
# Must be an EOA on Base (or whatever x402 network you target).
JOKE_SHOP_PAYEE_ADDRESS=0x0000000000000000000000000000000000000000

# Anthropic API key for generating jokes.
ANTHROPIC_API_KEY=sk-ant-...

# x402 facilitator URL. Defaults to Coinbase's CDP facilitator (mainnet support).
# For testnet-only use https://x402.org/facilitator (requires X402_NETWORK=base-sepolia).
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# CDP credentials for calls to the CDP facilitator. Not needed when using x402.org.
# Create at portal.cdp.coinbase.com → API Keys (Ed25519 or EC PEM both work).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Network the facilitator operates on — "base" for mainnet or "base-sepolia" for testnet.
X402_NETWORK=base

# Price per joke in USD. Supports micro-amounts down to $0.0001.
JOKE_PRICE_USD=$0.01

# HTTP port.
PORT=4021
